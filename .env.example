# Optional — defaults match the paths below (relative to the project root).
# SFBC_INPUT_DIR=docs/input_docs/2025
# SFBC_OUTPUT_DIR=output
# Inclusive posting-date range (YYYY-MM-DD or MM/DD/YYYY).
# If both are omitted, defaults to Jan 1–Dec 31 of the current calendar year.
# If only one is set, the other is inferred (Dec 31 or Jan 1 of that same year).
# SFBC_ANALYSIS_START=2025-01-01
# SFBC_ANALYSIS_END=2025-12-31
